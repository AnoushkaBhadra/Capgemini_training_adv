<persistence xmlns="http://java.sun.com/xml/ns/persistence" version = "2.0">
    <persistence-unit name="Maven7">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        <class>com.example.foreignkey.entities.Customer</class>
        <class>com.example.foreignkey.entities.Customer_Details</class>

        <properties>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:mysql://localhost:3306/jpa_demo"/>
            <property name="jakarta.persistence.jdbc.user" value="root"/>
            <property name="jakarta.persistence.jdbc.password" value="OT74ever"/>
            <property name="jakarta.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>

            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <property name="hibernate.show_sql" value="true"/>
        </properties>
    </persistence-unit>
</persistence>